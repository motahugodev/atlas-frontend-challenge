    "@nuxt/image": "^2.0.0",
    "@nuxt/ui": "^4.8.1",
    "@pinia/nuxt": "^0.11.3",
    "@vueuse/core": "^14.3.0",
    "nuxt": "^4.4.6",
    "nuxt-seo-utils": "8.3.1",
    "pinia": "^3.0.4",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@iconify-json/lucide": "^1.2.111",
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/test-utils": "^4.0.3",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "@vue/test-utils": "^2.4.11",
    "eslint": "^10.4.1",
